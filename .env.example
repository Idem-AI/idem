# ==================== FIREBASE CONFIGURATION ====================
# Firebase Auth & Admin SDK
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-content\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id

# ==================== DATABASE CONFIGURATION ====================
# PostgreSQL (for Ideploy/Coolify)
DB_CONNECTION=pgsql
DB_DATABASE=coolify
DB_USERNAME=coolify
DB_PASSWORD=password
DB_HOST=postgres
DB_PORT=5432
FORWARD_DB_PORT=5432

# MongoDB (for API)
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/idem?authSource=admin
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=admin123
MONGODB_DATABASE=idem

# ==================== REDIS CONFIGURATION ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=Idem
FORWARD_REDIS_PORT=6379

# ==================== MINIO CONFIGURATION ====================
# MinIO S3-compatible object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=idem-storage2

# ==================== AI CONFIGURATION ====================
# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Claude
CLAUDE_API_KEY=your-claude-api-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key

# AI Generation Limits
AI_MAX_OUTPUT_TOKENS=4000
AI_MAX_INPUT_TOKENS=128000
AI_STANDARD_TOKEN_LIMIT=128000
AI_PROVIDER=gemini

# ==================== API SERVICE CONFIGURATION ====================
API_PORT=3010
API_URL=http://localhost:3010
PORT=3001
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:3003,http://localhost:3004,http://localhost:8000

# ==================== IDEPLOY/COOLIFY CONFIGURATION ====================
APP_ENV=local
APP_NAME=Coolify Dev
APP_ID=coolify-dev
APP_KEY=base64:your-app-key-here
APP_URL=http://localhost:8000
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=error
SSH_MUX_ENABLED=false
IDEM_API_URL=http://api:3000

# Pusher/Soketi Configuration
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_ID=coolify
PUSHER_APP_KEY=coolify
PUSHER_APP_SECRET=coolify
FORWARD_SOKETI_PORT=6001

# Queue & Horizon
QUEUE_CONNECTION=redis
HORIZON_BALANCE=auto
HORIZON_MAX_PROCESSES=10
HORIZON_BALANCE_MAX_SHIFT=1
HORIZON_BALANCE_COOLDOWN=3

# Session & Cache
SESSION_DRIVER=redis
CACHE_DRIVER=redis

# Mail Configuration
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@idem.africa
MAIL_FROM_NAME=Idem

# Features
DOCKER_ENABLED=true
RAY_ENABLED=false
TELESCOPE_ENABLED=true

# ==================== VITE CONFIGURATION ====================
VITE_HOST=0.0.0.0
VITE_PORT=5173
VITE_API_BASE_URL=http://localhost:3001
VITE_LOG_LEVEL=info

# Mermaid/Chart Configuration
VITE_MERMAID_DOMAIN=
VITE_MERMAID_ANALYTICS_URL=
VITE_MERMAID_RENDERER_URL=https://mermaid.ink
VITE_MERMAID_KROKI_RENDERER_URL=https://kroki.io
VITE_MERMAID_IS_ENABLED_MERMAID_CHART_LINKS=

# ==================== APPGEN CONFIGURATION ====================
APPGEN_PORT=3003
CHART_PORT=3004

# React App (we-dev-client)
REACT_APP_BASE_URL=http://localhost:3000
REACT_APP_IDEM_API_BASE_URL=http://localhost:3001
REACT_APP_IDEM_MAIN_APP_URL=http://localhost:4200
REACT_APP_NEXT_API_BASE_URL=http://localhost:3000

# Next.js (we-dev-next)
THIRD_API_URL=https://generativelanguage.googleapis.com/v1beta
THIRD_API_KEY=your-third-api-key
IDEM_FRONTEND_URL=https://idem.africa

# Netlify Deployment
NETLIFY_TOKEN=your-netlify-token
NETLIFY_DEPLOY_URL=https://api.netlify.com/api/v1/sites

# ==================== EMAIL CONFIGURATION ====================
# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password

# Email Service
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@idem.africa

# ==================== SECURITY & ENCRYPTION ====================
SENSITIVE_VARS_ENCRYPTION_KEY=your-encryption-key-min-32-characters
INTERNAL_API_KEY=your-secure-api-key-here-change-in-production

# ==================== BETA CONFIGURATION ====================
IS_BETA=true
BETA_DAILY_QUOTA_LIMIT=50
BETA_WEEKLY_QUOTA_LIMIT=200
BETA_MAX_STYLES=3
BETA_MAX_RESOLUTION=1024
BETA_ALLOWED_FEATURES=branding,business-plan,diagrams
BETA_MAX_OUTPUT_TOKENS=4000
MIN_INPUT_LENGTH=10
MAX_INPUT_LENGTH=5000

# ==================== AUTHORIZATION ====================
ADMIN_EMAILS=admin@example.com

# ==================== GITHUB INTEGRATION ====================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3001/api/github/auth/callback

# ==================== USER & GROUP IDS (for Docker) ====================
USERID=1000
GROUPID=1000
