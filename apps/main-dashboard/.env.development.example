# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Services URLs - Development
SERVICES_DOMAIN=https://idem.africa
SERVICES_DASHBOARD_URL=http://localhost:4200
SERVICES_API_URL=http://localhost:3001
SERVICES_API_VERSION=v1
SERVICES_API_LLM_MODEL=gpt-3.5-turbo
SERVICES_WEBGEN_URL=http://localhost:5173
SERVICES_DIAGEN_URL=http://localhost:3002
SERVICES_IDEPLOY_URL=http://localhost:8000

# iDeploy API Token (CRITICAL - NEVER COMMIT THE REAL TOKEN)
IDEPLOY_API_TOKEN=your_dev_ideploy_api_token_here

# Other
WAITLIST_URL=https://forms.gle/your_dev_form_id
IS_BETA=true
ANALYTICS_ENABLED=false
