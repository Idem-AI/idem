# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Services URLs - Production
SERVICES_DOMAIN=https://idem.africa
SERVICES_API_URL=https://api.idem.africa
SERVICES_IDEPLOY_URL=https://ideploy.idem.africa
SERVICES_WEBGEN_URL=https://webgen.idem.africa
SERVICES_DIAGEN_URL=https://diagen.idem.africa

# Waitlist Form URL
WAITLIST_URL=https://forms.gle/your_waitlist_form_id

# iDeploy API Token (CRITICAL - NEVER COMMIT THE REAL TOKEN)
IDEPLOY_API_TOKEN=your_prod_ideploy_api_token_here

# Other
IS_BETA=true
ANALYTICS_ENABLED=true
