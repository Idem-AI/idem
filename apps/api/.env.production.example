# Production Environment Configuration Example
# Copy this file to .env.production and update with your production values

# Firebase Configuration (Auth only)
FIREBASE_AUTH_DOMAIN="lexis-ia.firebaseapp.com"
FIREBASE_PROJECT_ID="lexis-ia"
FIREBASE_STORAGE_BUCKET="lexis-ia.firebasestorage.app"
FIREBASE_MESSAGING_SENDER_ID="78825247320"
FIREBASE_APP_ID="1:78825247320:web:12c2eaa97dfaf1d5f3f02d"
FIREBASE_MEASUREMENT_ID="G-1YQGTP97EJ"
FIREBASE_PRIVATE_KEY_ID="your-production-key-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRODUCTION_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@lexis-ia.iam.gserviceaccount.com"
FIREBASE_CLIENT_ID="your-production-client-id"
AUT_URI="https://accounts.google.com/o/oauth2/auth"
TOKEN_URI="https://oauth2.googleapis.com/token"

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@your-mongodb-host:27017/idem?authSource=admin

# MinIO Configuration (S3-compatible object storage)
# For production with MinIO deployed on a custom domain
MINIO_ENDPOINT=storage.idem.africa
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-production-access-key
MINIO_SECRET_KEY=your-production-secret-key
MINIO_BUCKET_NAME=idem-storage
# Public URL for MinIO (IMPORTANT: This is what clients will use to access files)
# This should be your MinIO domain with HTTPS
MINIO_PUBLIC_URL=https://storage.idem.africa

# CORS Configuration
CORS_ALLOWED_ORIGINS="https://idem.africa,https://dashboard.idem.africa,https://api.idem.africa"

# Redis Configuration
REDIS_HOST="your-redis-host"
REDIS_PORT="6379"
REDIS_PASSWORD="your-redis-password"
REDIS_DB="Idem"

# Google AI Configuration
GEMINI_API_KEY="your-production-gemini-api-key"
DEEPSEEK_API_KEY=your-production-deepseek-api-key
OPENAI_API_KEY=your-production-openai-api-key

# GitHub Integration
GITHUB_CLIENT_ID=your-production-github-client-id
GITHUB_CLIENT_SECRET=your-production-github-client-secret
GITHUB_REDIRECT_URI=https://api.idem.africa/api/github/auth/callback

# Beta Configuration
IS_BETA=false
BETA_DAILY_QUOTA_LIMIT=100
BETA_WEEKLY_QUOTA_LIMIT=500
BETA_MAX_STYLES=5
BETA_MAX_RESOLUTION=2048
BETA_ALLOWED_FEATURES=branding,business-plan,diagrams,deployment
BETA_MAX_OUTPUT_TOKENS=8000
MIN_INPUT_LENGTH=10
MAX_INPUT_LENGTH=10000

# Server Configuration
PORT=3001
NODE_ENV=production

# Authorization System
ADMIN_EMAILS=admin@idem.africa
APP_URL=https://idem.africa

# Email Service Configuration
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=your-production-email-api-key
EMAIL_FROM=noreply@idem.africa

# SMTP Configuration for Contact Form
SMTP_HOST=smtp.privateemail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@idem.africa
SMTP_PASS="your-production-smtp-password"

# Security Keys
SENSITIVE_VARS_ENCRYPTION_KEY="your-production-encryption-key-change-this"

# Inter-Service Authentication
INTERNAL_API_KEY=your-production-internal-api-key-change-this

# iDeploy SSO shared secret (must match IDEPLOY_SHARED_SECRET in iDeploy .env)
IDEPLOY_SHARED_SECRET=your-production-shared-secret-change-this
