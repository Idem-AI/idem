# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3002
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:4202,http://localhost:8000

# ── PostgreSQL (SHARED with the Laravel app — same schema) ──
# Prisma uses DATABASE_URL; the raw pg pool uses the IDEPLOY_DB_* vars.
DATABASE_URL=postgresql://coolify:password@localhost:5432/coolify?schema=public
IDEPLOY_DB_HOST=localhost
IDEPLOY_DB_PORT=5432
IDEPLOY_DB_DATABASE=coolify
IDEPLOY_DB_USERNAME=coolify
IDEPLOY_DB_PASSWORD=password

# ── Laravel-compatible crypto ───────────────────────────
# MUST be the exact same APP_KEY as apps/ideploy/.env (format: base64:....)
# Required to read/write the encrypted columns (SSH keys, tokens, secrets).
APP_KEY=

# ── Redis (queue + cache) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Authentication (delegated to the central Idem API) ──
# iDeploy does NOT authenticate users. It verifies the `session` cookie by
# calling the central Idem API /auth/profile. No Firebase credentials here.
IDEM_API_URL=http://localhost:3001

# ── Realtime (Soketi / Pusher protocol) ─────────────────
PUSHER_APP_ID=ideploy
PUSHER_APP_KEY=ideploy
PUSHER_APP_SECRET=ideploy-secret
PUSHER_HOST=localhost
PUSHER_PORT=6001
PUSHER_SCHEME=http
