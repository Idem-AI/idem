generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model activity_log {
  id           BigInt    @id @default(autoincrement())
  log_name     String?   @db.VarChar(255)
  description  String
  subject_type String?   @db.VarChar(255)
  subject_id   BigInt?
  causer_type  String?   @db.VarChar(255)
  causer_id    BigInt?
  properties   Json?
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  event        String?   @db.VarChar(255)
  batch_uuid   String?   @db.Uuid

  @@index([log_name], map: "activity_log_log_name_index")
  @@index([causer_type, causer_id], map: "causer")
  @@index([properties(ops: JsonbPathOps)], map: "idx_activity_type_uuid", type: Gin)
  @@index([subject_type, subject_id], map: "subject")
}

model additional_destinations {
  id                   BigInt             @id @default(autoincrement())
  application_id       BigInt
  server_id            BigInt
  status               String             @default("exited") @db.VarChar(255)
  standalone_docker_id BigInt
  created_at           DateTime?          @db.Timestamp(0)
  updated_at           DateTime?          @db.Timestamp(0)
  applications         applications       @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "additional_destinations_application_id_foreign")
  servers              servers            @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "additional_destinations_server_id_foreign")
  standalone_dockers   standalone_dockers @relation(fields: [standalone_docker_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "additional_destinations_standalone_docker_id_foreign")
}

model analytics_configs {
  id             BigInt       @id @default(autoincrement())
  application_id BigInt
  provider       String       @default("plausible") @db.VarChar(255)
  enabled        Boolean      @default(false)
  site_id        String?      @db.VarChar(255)
