  created_at     DateTime?    @db.Timestamp(0)
  updated_at     DateTime?    @db.Timestamp(0)
  applications   applications @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "analytics_configs_application_id_foreign")

  @@index([application_id], map: "analytics_configs_application_id_index")
}

