// iDeploy database schema — INTROSPECTION ONLY.
//
// The PostgreSQL schema is owned by the existing Laravel migrations
// (apps/ideploy/database/migrations/**). We NEVER author structural
// migrations here. Instead we mirror the live schema with:
//
//   npm run prisma:introspect   (= prisma db pull && prisma generate)
//
// `prisma db pull` reads the live database (already migrated by Laravel)
// and regenerates the `model` blocks below in place. Re-run it whenever
// Laravel adds a migration during the strangler-fig transition.
//
// Keep `relationMode = "prisma"` OFF: the real FKs exist in the DB, so
// Prisma should rely on them. Do not add @@map renames by hand — let
// introspection populate everything.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ⚠️ Models below are auto-generated by `prisma db pull`. Do not edit by hand.
// (empty until the first introspection against the running iDeploy database)
